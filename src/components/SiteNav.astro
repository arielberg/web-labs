---
const path = Astro.url.pathname;
const links = [
  { href: '/', label: 'בית', match: (p: string) => p === '/' },
  { href: '/articles/', label: 'מאמרים', match: (p: string) => p.startsWith('/articles') },
  { href: '/news/', label: 'חדשות', match: (p: string) => p.startsWith('/news') },
  { href: '/about/', label: 'עלינו', match: (p: string) => p.startsWith('/about') },
];
---

<header class="site-header" id="topbar">
  <button
    type="button"
    class="menu-toggle"
    id="navToggle"
    aria-expanded="false"
    aria-controls="siteNav"
    aria-label="תפריט ניווט"
  >
    <span class="menu-toggle__bars" aria-hidden="true">
      <i></i><i></i><i></i>
    </span>
  </button>

  <nav class="site-nav" id="siteNav" aria-label="ניווט ראשי">
    {
      links.map((link) => (
        <a
          href={link.href}
          class:list={['site-nav__link', { 'is-active': link.match(path) }]}
          aria-current={link.match(path) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <div class="site-header__actions">
    <button type="button" class="header-cta" data-mode="chat" aria-label="צ׳אט">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
        ><path
          d="M5 6.5A2.5 2.5 0 0 1 7.5 4h9A2.5 2.5 0 0 1 19 6.5v7A2.5 2.5 0 0 1 16.5 16H11l-4 3.5V16H7.5A2.5 2.5 0 0 1 5 13.5v-7Z"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linejoin="round"></path></svg
      >
      <span data-i18n="cta.chat">צ׳אט</span>
    </button>
    <button type="button" class="header-cta" data-mode="phone" aria-label="טלפון">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"
        ><path
          d="M7.5 3.5h3l1.2 4.2-2 1.4a12.5 12.5 0 0 0 5.2 5.2l1.4-2 4.2 1.2v3A1.8 1.8 0 0 1 18.7 18 14.5 14.5 0 0 1 6 5.3a1.8 1.8 0 0 1 1.5-1.8Z"
          stroke="currentColor"
          stroke-width="1.7"
          stroke-linejoin="round"></path></svg
      >
      <span data-i18n="cta.phone">טלפון</span>
    </button>
  </div>

  <div class="site-header__tools" id="topTools" aria-hidden="true"></div>

  <a class="site-header__brand" href="/" aria-label="Web Labs">
    <img class="site-header__logo" src="/logo.svg" alt="" width="48" height="36" />
  </a>

  <button type="button" class="lang-btn" id="langToggle" aria-label="Switch language">EN</button>
</header>
