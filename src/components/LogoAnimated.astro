---
interface Props {
  uid?: string;
  class?: string;
}

const { uid = 'wl', class: className = '' } = Astro.props;
const cyan = `${uid}-cyan`;
const shine = `${uid}-shine`;
const glow = `${uid}-glow`;
const smallGlow = `${uid}-smallGlow`;
const textMask = `${uid}-textMask`;
const drawPath = `${uid}-drawPath`;
const drawAnim = `${uid}-draw`;
const drawBeginSec = 0.12;
const drawDurSec = 1.15;
const drawEndSec = drawBeginSec + drawDurSec;
const drawBegin = `${drawBeginSec}s`;
const drawDur = `${drawDurSec}s`;
const drawEnd = `${drawEndSec}s`;
---

<svg
  class:list={['logo-animated', className]}
  xmlns="http://www.w3.org/2000/svg"
  width="320"
  height="120"
  viewBox="48 40 270 95"
  role="img"
  aria-label="Web Labs"
  style={`--logo-draw-end: ${drawEndSec}s`}
>
  <defs>
    <linearGradient id={cyan} x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#00b7ff"></stop>
      <stop offset=".5" stop-color="#67efff"></stop>
      <stop offset="1" stop-color="#6b8dff"></stop>
    </linearGradient>

    <linearGradient id={shine} x1="0" x2="1">
      <stop offset="0" stop-color="white" stop-opacity="0"></stop>
      <stop offset=".5" stop-color="white" stop-opacity=".9"></stop>
      <stop offset="1" stop-color="white" stop-opacity="0"></stop>
    </linearGradient>

    <filter id={glow} x="-300%" y="-300%" width="700%" height="700%">
      <feGaussianBlur stdDeviation="7"></feGaussianBlur>
    </filter>

    <filter id={smallGlow} x="-300%" y="-300%" width="700%" height="700%">
      <feGaussianBlur stdDeviation="2"></feGaussianBlur>
    </filter>

    <mask id={textMask}>
      <rect x="48" y="40" width="270" height="95" fill="black"></rect>
      <rect x="130" y="68" width="0" height="40" fill="white">
        <animate
          attributeName="width"
          from="0"
          to="170"
          begin={drawEnd}
          dur="0.45s"
          fill="freeze"></animate>
      </rect>
    </mask>
  </defs>

  <ellipse cx="175" cy="75" rx="120" ry="40" fill="#00d8ff" opacity=".06" filter={`url(#${glow})`}
  ></ellipse>

  <!-- W + bar (tight bounds: x≈58–300, y≈55–113) -->
  <path
    id={drawPath}
    d="M58 55 L76 113 L94 73 L112 113 L130 55 L300 55"
    fill="none"
    stroke={`url(#${cyan})`}
    stroke-width="8"
    stroke-linecap="round"
    stroke-linejoin="round"
    pathLength="1000"
    stroke-dasharray="1000"
    stroke-dashoffset="1000"
  >
    <animate
      id={drawAnim}
      attributeName="stroke-dashoffset"
      from="1000"
      to="0"
      begin={drawBegin}
      dur={drawDur}
      fill="freeze"></animate>
  </path>

  <!-- Tip orb at stroke leading edge -->
  <g class="logo-animated__orb" opacity="0">
    <circle r="18" fill="#4de8ff" opacity=".28" filter={`url(#${glow})`}></circle>
    <circle r="8" fill="#fff" opacity=".5"></circle>
    <circle r="2.8" fill="white"></circle>
    <animate
      attributeName="opacity"
      values="0;1;1;0"
      keyTimes="0;0.02;0.88;1"
      begin={drawBegin}
      dur="1.4s"
      fill="freeze"></animate>
    <animateMotion
      begin={drawBegin}
      dur={drawDur}
      fill="freeze"
      rotate="auto"
      calcMode="linear"
      keyPoints="0;1"
      keyTimes="0;1"
    >
      <mpath href={`#${drawPath}`}></mpath>
    </animateMotion>
  </g>

  <circle cx="58" cy="55" r="0" fill="#4de8ff" opacity="0" filter={`url(#${glow})`}>
    <animate
      attributeName="opacity"
      values="0;.85;0"
      keyTimes="0;.45;1"
      begin="0s"
      dur="0.28s"
      fill="freeze"></animate>
    <animate
      attributeName="r"
      values="0;22;36"
      keyTimes="0;.45;1"
      begin="0s"
      dur="0.28s"
      fill="freeze"></animate>
  </circle>

  <!-- Center glow: same orb language as the tip, settles in the W after draw -->
  <g class="logo-animated__core" transform="translate(94 90)">
    <circle r="22" fill="#4de8ff" opacity=".4" filter={`url(#${glow})`}></circle>
    <circle r="10" fill="#fff" opacity=".3"></circle>
    <circle r="2.2"  opacity=".5" fill="white"></circle>
  </g>

  <!-- Word under the bar; opacity via <g> + CSS (reliable) -->
  <g class="logo-animated__word">
    <text
      x="136"
      y="92"
      direction="ltr"
      text-anchor="start"
      font-size="34"
      font-family="'Space Grotesk', Arial, sans-serif"
      font-weight="700"
      letter-spacing="-0.02em"
      fill="#f4fbff"
    >
      eb-labs
    </text>
  </g>

  <g mask={`url(#${textMask})`}>
    <rect
      x="100"
      y="50"
      width="18"
      height="55"
      fill={`url(#${shine})`}
      transform="skewX(-20)"
      filter={`url(#${smallGlow})`}
      opacity="0"
    >
      <animate
        attributeName="opacity"
        values="0;1;1;0"
        keyTimes="0;0.12;0.75;1"
        begin={`${drawEndSec + 0.05}s`}
        dur="0.7s"
        fill="freeze"></animate>
      <animate
        attributeName="x"
        values="100;300"
        begin={`${drawEndSec + 0.05}s`}
        dur="0.7s"
        fill="freeze"></animate>
    </rect>
  </g>
</svg>

<style>
  .logo-animated {
    display: block;
    width: 100%;
    height: auto;
    max-width: min(22rem, 88vw);
    direction: ltr;
    overflow: visible;
  }

  .logo-animated__word {
    opacity: 0;
    animation: logo-fade-in 0.45s ease forwards;
    animation-delay: var(--logo-draw-end, 1.27s);
  }

  .logo-animated__core {
    opacity: 0;
    animation:
      logo-fade-in 2.85s ease forwards,
      logo-core-blink 3.8s ease-in infinite;
    animation-delay: var(--logo-draw-end, 1.27s), calc(var(--logo-draw-end, 1.27s) + 0.45s);
  }

  @keyframes logo-fade-in {
    to {
      opacity: 1;
    }
  }

  @keyframes logo-core-blink {
    0%,
    100% {
      opacity: 0.28;
    }
    45% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-animated animate,
    .logo-animated animateMotion {
      display: none;
    }

    .logo-animated path {
      stroke-dashoffset: 0 !important;
    }

    .logo-animated__word,
    .logo-animated__core {
      opacity: 1;
      animation: none;
    }
  }
</style>
